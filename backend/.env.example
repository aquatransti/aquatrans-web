PORT=5001
NODE_ENV=development

# Segredo JWT - use uma string longa e aleatória (ex: openssl rand -base64 32)
JWT_SECRET=ALTERE_PARA_UMA_CHAVE_SECRETA_FORTE

# Chave de API para o webhook do Google Forms
GOOGLE_FORMS_API_KEY=ALTERE_PARA_UMA_CHAVE_SECRETA_FORTE

# Senha padrão para usuários de desenvolvimento (NÃO use em produção)
DEFAULT_USER_PASSWORD=ALTERE_PARA_UMA_SENHA_DE_DESENVOLVIMENTO

# Configurações de email (Gmail com App Password)
EMAIL_USER=maya@aquatrans.org.br
EMAIL_PASS=sua-app-password-do-gmail

# Conta gestor padrão para desenvolvimento
# Email: maya@aquatrans.org.br
# Senha: valor de DEFAULT_USER_PASSWORD

# URL do frontend (para links nos emails)
FRONTEND_URL=http://localhost:3000
